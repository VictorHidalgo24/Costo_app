<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Icono del tipo de medidor (agua, luz o gas) -->
    <ImageView
        android:id="@+id/iconoMedidor"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/icono_medidor"
        tools:src="@drawable/ic_agua" />

    <!-- Tipo de medidor -->
    <TextView
        android:id="@+id/textoTipoMedidor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="AGUA" />

    <!-- Valor del medidor -->
    <TextView
        android:id="@+id/textoValorMedidor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="16sp"
        android:gravity="center"
        tools:text="1500" />

    <!-- Fecha de la medicion -->
    <TextView
        android:id="@+id/textoFecha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="14sp"
        android:gravity="end"
        tools:text="2024-01-13" />

</LinearLayout>
